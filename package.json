{
  "name": "nbp-api-client",
  "version": "1.0.1",
  "description": "Library that enables easy retrieval and processing of data from the National Bank of Poland (NBP) API, such as exchange rates and historical currency data. A simple interface allows quick integration of financial data into your applications.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miqel-dll/nbp-api-client.git"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "nbp",
    "api",
    "library",
    "nbp library",
    "national polish bank",
    "national polish bank api"
  ],
  "author": "miqel-dll",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "coverage": "jest --coverage",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build && npm run lint && npm run test"
  },
  "bugs": {
    "url": "https://github.com/miqel-dll/nbp-api-client/issues"
  },
  "homepage": "https://github.com/miqel-dll/nbp-api-client#readme",
  "sideEffects": false,
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "globals": {
      "ts-jest": {
        "diagnostics": { "ignoreCodes": [151002] }
      }
    },
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "testMatch": [
      "**/src/**/*.test.ts"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6"
  },
  "dependencies": {
}
}
